
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% if product.images.size > 0 %}
{% style %}
  .ai-product-gallery-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-product-gallery__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  .ai-product-gallery__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-product-gallery__title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
    font-size: 36px;
  }

  .ai-product-gallery__subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0;
    font-size: 16px;
    opacity: 0.8;
  }

  .ai-product-gallery__grid-{{ ai_gen_id }} {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
  }

  .ai-product-gallery__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-product-gallery__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    {% if block.settings.image_ratio == 'natural' %}
      aspect-ratio: auto;
    {% elsif block.settings.image_ratio == 'square' %}
      aspect-ratio: 1 / 1;
    {% elsif block.settings.image_ratio == 'portrait' %}
      aspect-ratio: 2 / 3;
    {% elsif block.settings.image_ratio == 'landscape' %}
      aspect-ratio: 4 / 3;
    {% endif %}
  }

  .ai-product-gallery__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-product-gallery__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-product-gallery__grid-{{ ai_gen_id }} {
      {% if block.settings.enable_mobile_slider %}
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        gap: 12px;
        padding-bottom: 10px;
      {% else %}
        {% if block.settings.columns_mobile == '1' %}
          grid-template-columns: 1fr;
        {% else %}
          grid-template-columns: repeat(2, 1fr);
        {% endif %}
      {% endif %}
    }

    {% if block.settings.enable_mobile_slider %}
      .ai-product-gallery__item-{{ ai_gen_id }} {
        flex: 0 0 85%;
        scroll-snap-align: start;
      }
    {% endif %}

    .ai-product-gallery__title-{{ ai_gen_id }} {
      font-size: 28px;
    }

    .ai-product-gallery__subtitle-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<product-gallery-{{ ai_gen_id }} class="ai-product-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-gallery__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-product-gallery__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-product-gallery__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-product-gallery__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-product-gallery__grid-{{ ai_gen_id }}">
      {% if product.images.size > 0 %}
        {% for image in product.images %}
          <div class="ai-product-gallery__item-{{ ai_gen_id }}">
            <div class="ai-product-gallery__image-wrapper-{{ ai_gen_id }}">
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-product-gallery__image-{{ ai_gen_id }}"
              >
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..6) %}
          <div class="ai-product-gallery__item-{{ ai_gen_id }}">
            <div class="ai-product-gallery__image-wrapper-{{ ai_gen_id }}">
              <div class="ai-product-gallery__placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</product-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const grid = this.querySelector('.ai-product-gallery__grid-{{ ai_gen_id }}');
        if (!grid) return;

        if (window.innerWidth <= 749 && {{ block.settings.enable_mobile_slider | json }}) {
          this.setupMobileSlider(grid);
        }
      }

      setupMobileSlider(grid) {
        let isDown = false;
        let startX;
        let scrollLeft;

        grid.addEventListener('mousedown', (e) => {
          isDown = true;
          startX = e.pageX - grid.offsetLeft;
          scrollLeft = grid.scrollLeft;
        });

        grid.addEventListener('mouseleave', () => {
          isDown = false;
        });

        grid.addEventListener('mouseup', () => {
          isDown = false;
        });

        grid.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - grid.offsetLeft;
          const walk = (x - startX) * 2;
          grid.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('product-gallery-{{ ai_gen_id }}', ProductGallery{{ ai_gen_id }});
  })();
</script>
{% endif %}
{% schema %}
{
  "name": "Product gallery",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Product Gallery"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Explore our product from every angle"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "enable_mobile_slider",
      "label": "Enable slider on mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        {
          "value": "natural",
          "label": "Natural"
        },
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1d212a"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Product gallery"
    }
  ]
}
{% endschema %}
