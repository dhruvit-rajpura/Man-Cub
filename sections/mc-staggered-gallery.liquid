{%- comment -%}
  MC Staggered Gallery - Asymmetric 3+2 repeating pattern
  Every 5 images: Row 1 = small + large + medium, Row 2 = wide + tall
  Images auto-arrange in this pattern no matter how many you add
{%- endcomment -%}

<div class="mc-stagger" id="mcStagger-{{ section.id }}">
  {%- assign total = section.blocks.size -%}
  {%- assign i = 0 -%}

  {%- for block in section.blocks -%}
    {%- assign pos = i | modulo: 5 -%}

    {%- comment -%} Start Row 1 (positions 0,1,2) {%- endcomment -%}
    {%- if pos == 0 -%}
      <div class="mc-stagger__row mc-stagger__row--three">
    {%- endif -%}

    {%- comment -%} Start Row 2 (positions 3,4) {%- endcomment -%}
    {%- if pos == 3 -%}
      <div class="mc-stagger__row mc-stagger__row--two">
    {%- endif -%}

    {%- comment -%} Assign size class based on position in the 5-image pattern {%- endcomment -%}
    {%- case pos -%}
      {%- when 0 -%}{%- assign size_class = 'mc-stagger__item--sm' -%}
      {%- when 1 -%}{%- assign size_class = 'mc-stagger__item--lg' -%}
      {%- when 2 -%}{%- assign size_class = 'mc-stagger__item--md' -%}
      {%- when 3 -%}{%- assign size_class = 'mc-stagger__item--wide' -%}
      {%- when 4 -%}{%- assign size_class = 'mc-stagger__item--tall' -%}
    {%- endcase -%}

    <{% if block.settings.link != blank %}a href="{{ block.settings.link }}"{% else %}div{% endif %}
      class="mc-stagger__item {{ size_class }} mc-scroll-fade"
      {{ block.shopify_attributes }}
    >
      {%- if block.settings.image != blank -%}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 768px) 50vw, 40vw"
          alt="{{ block.settings.caption | default: 'Gallery image' | escape }}"
          loading="lazy"
          style="object-position: {{ block.settings.image_position | default: 'center' }};"
        >
      {%- else -%}
        <div class="mc-stagger__placeholder"></div>
      {%- endif -%}
      {%- if block.settings.caption != blank -%}
        <div class="mc-stagger__caption">
          <p>{{ block.settings.caption }}</p>
        </div>
      {%- endif -%}
    </{% if block.settings.link != blank %}a{% else %}div{% endif %}>

    {%- comment -%} Close Row 1 after position 2 or if last item {%- endcomment -%}
    {%- if pos == 2 or forloop.last -%}
      {%- if pos == 0 or pos == 1 or pos == 2 -%}
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- comment -%} Close Row 2 after position 4 or if last item {%- endcomment -%}
    {%- if pos == 4 or forloop.last -%}
      {%- if pos == 3 or pos == 4 -%}
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- assign i = i | plus: 1 -%}
  {%- endfor -%}
</div>

<style>
.mc-stagger {
  max-width: 1100px; margin: 0 auto; padding: 20px 30px 50px;
}

/* Row 1: 3 images - small / large / medium with stagger */
.mc-stagger__row--three {
  display: grid;
  grid-template-columns: 25fr 42fr 30fr;
  gap: 20px;
  margin-bottom: 20px;
  align-items: end;
}

/* Row 2: 2 images - wide / tall */
.mc-stagger__row--two {
  display: grid;
  grid-template-columns: 55fr 42fr;
  gap: 20px;
  margin-bottom: 40px;
}

/* Base item */
.mc-stagger__item {
  display: block; position: relative; overflow: hidden;
  text-decoration: none; background: #f5f5f5;
}
.mc-stagger__item img {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%; object-fit: cover;
}

/* Sizes - Row 1 */
.mc-stagger__item--sm { height: 240px; align-self: end; }
.mc-stagger__item--lg { height: 380px; }
.mc-stagger__item--md { height: 300px; align-self: start; }

/* Sizes - Row 2 */
.mc-stagger__item--wide { height: 380px; }
.mc-stagger__item--tall { height: 460px; align-self: start; margin-top: -40px; }

/* Caption overlay */
.mc-stagger__caption {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 100%);
  padding: 20px 16px 14px;
}
.mc-stagger__caption p {
  color: #fff; font-family: 'Instrument Sans', sans-serif;
  font-size: 11px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.06em; margin: 0; line-height: 1.4;
}

.mc-stagger__placeholder { width: 100%; height: 100%; background: #eee; }

/* Animations */
.mc-scroll-fade { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; }
.mc-scroll-fade.is-visible { opacity: 1; transform: translateY(0); }

/* Mobile */
@media(max-width:768px) {
  .mc-stagger { padding: 10px 16px 30px; }
  .mc-stagger__row--three {
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .mc-stagger__row--three .mc-stagger__item--lg {
    grid-column: span 2;
  }
  .mc-stagger__row--two {
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .mc-stagger__item--sm { height: 180px; }
  .mc-stagger__item--lg { height: 260px; }
  .mc-stagger__item--md { height: 200px; align-self: end; }
  .mc-stagger__item--wide { height: 260px; }
  .mc-stagger__item--tall { height: 320px; margin-top: 0; }
}
</style>

<script>
(function() {
  var els = document.querySelectorAll('#mcStagger-{{ section.id }} .mc-scroll-fade');
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.1 });
    els.forEach(function(el) { obs.observe(el); });
  } else { els.forEach(function(el) { el.classList.add('is-visible'); }); }
})();
</script>

{% schema %}
{
  "name": "MC Staggered Gallery",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "select", "id": "image_position", "label": "Image Focus Point",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "bottom", "label": "Bottom" },
            { "value": "left center", "label": "Left" },
            { "value": "right center", "label": "Right" }
          ],
          "default": "center"
        },
        { "type": "text", "id": "caption", "label": "Caption", "default": "MANCUBERS wearing our..." },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [{
    "name": "MC Staggered Gallery",
    "blocks": [
      { "type": "image" },
      { "type": "image" },
      { "type": "image" },
      { "type": "image" },
      { "type": "image" }
    ]
  }]
}
{% endschema %}
