{%- liquid
  assign vertical_position = 100 | minus: vertical_position
  assign delay_value = 0.3 | times: index
  assign animation_delay = 1 | plus: delay_value
-%}

<div
  class="
    shoppable-item
    shoppable-item--index-{{ index }}
    shoppable-item--animating
    shoppable-item--position-unset
    shoppable-item--{{ settings.product_listing_aspect_ratio }}
    {% unless product_item == blank or show_hotspot_cards == false %}
      animation--shoppable-item
    {% endunless %}
  "
  style="
    --horizontal-position: {{ horizontal_position }}%;
    --vertical-position: {{ vertical_position }}%;
    --mobile-horizontal: {{ mobile_horizontal | default: horizontal_position }}%;
    --mobile-vertical: {{ mobile_vertical | default: vertical_position }}%;
    --animation-delay: {{ animation_delay }}s;
  "
  data-index="{{index}}"
>
  {%- capture hotspot_tag -%}{% if product_item != blank %}button{% else %}div{% endif %}{%- endcapture -%}
  {%- capture hotspot_tag_attributes -%}{% if product_item != blank %}aria-label="{{ 'general.accessibility.access_more_details_about_product' | t: product_title: product_item.title }}" type="button"{% endif %} aria-roledescription="{{ "sections.shoppable_image.hotspot_description" | t }}"{%- endcapture -%}
  <div class="shoppable-item__hotspot-wrapper animation--hotspot">
    <{{ hotspot_tag }}
      class="shoppable-item__hotspot mc-hotspot-plus"
      {{ hotspot_tag_attributes }}
      data-index="{{index}}"
      {{ block.shopify_attributes }}
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
    </{{ hotspot_tag }}>
  </div>

  {%- unless product_item == blank or show_hotspot_cards == false -%}
    {%- liquid
      assign si_price = product_item.price
      if product_item.price == 0
        assign si_kid = product_item.metafields.custom.kid_product.value
        assign si_man = product_item.metafields.custom.man_product.value
        assign si_woman = product_item.metafields.custom.women_product.value
        if si_kid != blank or si_man != blank or si_woman != blank
          assign si_price = 0
          if si_kid != blank
            assign si_price = si_price | plus: si_kid.price
          endif
          if si_man != blank
            assign si_price = si_price | plus: si_man.price
          endif
          if si_woman != blank
            assign si_price = si_price | plus: si_woman.price
          endif
        endif
      endif
    -%}
    <div
      class="
        shoppable-item__product-card
        mc-card-desktop--{{ card_size_desktop | default: 'medium' }}
        mc-card-mobile--{{ card_size_mobile | default: 'medium' }}
        {% if horizontal_position >= 50 %}shoppable-item__product-card--align-right{% endif %}
        {% assign mob_h = mobile_horizontal | default: horizontal_position %}
        {% if mob_h < 50 %}mc-card-mobile--flip-right{% endif %}
        {% if mob_h >= 50 %}mc-card-mobile--flip-left{% endif %}
        hidden
      "
      aria-hidden="true"
      aria-live="polite"
      role="region"
    >
      <div class="shoppable-item__product-card-inner mc-shoppable-card">
        {%- if product_item.featured_image != blank -%}
          <a href="{{ product_item.url }}" class="mc-shoppable-card__image">
            <img
              src="{{ product_item.featured_image | image_url: width: 300 }}"
              alt="{{ product_item.featured_image.alt | default: product_item.title | escape }}"
              loading="lazy"
            >
          </a>
        {%- endif -%}
        <div class="mc-shoppable-card__right">
          <a href="{{ product_item.url }}" class="mc-shoppable-card__title">{{ product_item.title }}</a>
          <div class="mc-shoppable-card__bottom-row">
            <span class="mc-shoppable-card__price">{{ si_price | money }}</span>
            {%- if product_item.available -%}
              <form method="post" action="/cart/add" class="mc-shoppable-card__atc-form" data-mc-shoppable-atc>
                <input type="hidden" name="id" value="{{ product_item.selected_or_first_available_variant.id }}">
                <input type="hidden" name="quantity" value="1">
                <button type="submit" class="mc-shoppable-card__atc">+ Add to Bag</button>
              </form>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>

    <style>
      /* + icon hotspot — override base theme dot */
      .shoppable-item__hotspot.mc-hotspot-plus {
        width: 34px !important;
        height: 34px !important;
        min-width: 34px !important;
        min-height: 34px !important;
        border-radius: 50% !important;
        background: rgba(255,255,255,0.92) !important;
        border: none !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        color: #000 !important;
        cursor: pointer !important;
        box-shadow: 0 2px 8px rgba(0,0,0,0.18) !important;
        padding: 0 !important;
        line-height: 0 !important;
        animation: none !important;
      }
      .shoppable-item__hotspot.mc-hotspot-plus::before {
        display: none !important;
      }
      .shoppable-item__hotspot.mc-hotspot-plus::after {
        display: none !important;
      }
      .shoppable-item__hotspot.mc-hotspot-plus:hover,
      .active .shoppable-item__hotspot.mc-hotspot-plus {
        transform: scale(1.12) !important;
        box-shadow: 0 3px 14px rgba(0,0,0,0.28) !important;
        background: rgba(255,255,255,1) !important;
      }
      .shoppable-item--animating .shoppable-item__hotspot.mc-hotspot-plus {
        animation: none !important;
      }
      .mc-hotspot-plus svg {
        width: 14px;
        height: 14px;
        display: block;
        flex-shrink: 0;
        pointer-events: none;
      }
      .mc-hotspot-plus * {
        pointer-events: none;
      }
      /* Make the whole hotspot wrapper clickable too */
      .shoppable-item__hotspot-wrapper {
        cursor: pointer;
      }

      /* Product card popup — override base theme */
      .shoppable-item__product-card {
        min-width: 280px !important;
        max-width: 320px !important;
        border-radius: 4px !important;
        overflow: hidden !important;
      }
      .shoppable-item__product-card .shoppable-item__product-card-inner.mc-shoppable-card,
      html.do-anim .animation .animation--shoppable-item .shoppable-item__product-card-inner.mc-shoppable-card,
      html.do-anim .animation .shoppable-item__product-card-inner.mc-shoppable-card {
        display: flex !important;
        flex-direction: row !important;
        align-items: stretch !important;
        max-width: none !important;
        min-width: 0 !important;
        padding: 0 !important;
        margin: 0 !important;
        text-decoration: none !important;
        color: inherit !important;
        background: #fff !important;
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
      .mc-shoppable-card__image {
        width: 90px;
        min-width: 90px;
        flex-shrink: 0;
        overflow: hidden;
        background: #f5f5f5;
        display: block;
      }
      .mc-shoppable-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .mc-shoppable-card__right {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 10px 12px;
        flex: 1;
        min-width: 0;
      }
      .mc-shoppable-card__title {
        font-family: var(--font-heading);
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        line-height: 1.35;
        color: #000;
        text-decoration: none;
        display: block;
      }
      .mc-shoppable-card__bottom-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        margin-top: auto;
        padding-top: 6px;
      }
      .mc-shoppable-card__price {
        font-size: 13px;
        font-weight: 600;
        color: #000;
      }
      .mc-shoppable-card__atc-form {
        margin: 0;
      }
      .mc-shoppable-card__atc {
        background: none;
        border: none;
        cursor: pointer;
        font-family: inherit;
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #555;
        padding: 0;
        white-space: nowrap;
        transition: color 0.2s;
      }
      .mc-shoppable-card__atc:hover {
        color: #000;
      }

      /* Desktop card sizes */
      .mc-card-desktop--small.shoppable-item__product-card { min-width: 220px !important; max-width: 250px !important; }
      .mc-card-desktop--small .mc-shoppable-card__image { width: 70px; min-width: 70px; }
      .mc-card-desktop--medium.shoppable-item__product-card { min-width: 280px !important; max-width: 320px !important; }
      .mc-card-desktop--medium .mc-shoppable-card__image { width: 90px; min-width: 90px; }
      .mc-card-desktop--large.shoppable-item__product-card { min-width: 340px !important; max-width: 380px !important; }
      .mc-card-desktop--large .mc-shoppable-card__image { width: 110px; min-width: 110px; }

      @media (max-width: 959px) {
        .mc-hotspot-plus {
          width: 28px !important;
          height: 28px !important;
          min-width: 28px !important;
          min-height: 28px !important;
        }
        .mc-hotspot-plus svg {
          width: 12px;
          height: 12px;
        }
        .shoppable-item__product-card {
          min-width: 200px !important;
          max-width: 250px !important;
        }
        .mc-shoppable-card {
          padding: 8px !important;
          gap: 0 !important;
        }
        .mc-shoppable-card__image {
          width: 55px !important;
          min-width: 55px !important;
          height: auto !important;
        }
        .mc-shoppable-card__title {
          font-size: 10px !important;
        }
        .mc-shoppable-card__price {
          font-size: 11px !important;
        }
        .mc-shoppable-card__atc {
          font-size: 8px !important;
        }
        .mc-shoppable-card__right {
          padding: 0 0 0 8px !important;
        }

        /* Flip card based on hotspot position */
        .mc-card-mobile--flip-right.shoppable-item__product-card {
          left: calc(var(--horizontal-position) + 20px) !important;
          right: auto !important;
        }
        .mc-card-mobile--flip-left.shoppable-item__product-card {
          left: auto !important;
          right: calc((100% - var(--horizontal-position)) + 20px) !important;
        }

        /* Mobile card sizes */
        .mc-card-mobile--small.shoppable-item__product-card { min-width: 180px !important; max-width: 210px !important; }
        .mc-card-mobile--small .mc-shoppable-card__image { width: 45px !important; min-width: 45px !important; }
        .mc-card-mobile--medium.shoppable-item__product-card { min-width: 200px !important; max-width: 250px !important; }
        .mc-card-mobile--medium .mc-shoppable-card__image { width: 55px !important; min-width: 55px !important; }
        .mc-card-mobile--large.shoppable-item__product-card { min-width: 240px !important; max-width: 290px !important; }
        .mc-card-mobile--large .mc-shoppable-card__image { width: 70px !important; min-width: 70px !important; }
      }
    </style>

    <script>
      (function() {
        document.querySelectorAll('[data-mc-shoppable-atc]').forEach(function(form) {
          if (form._mcInit) return;
          form._mcInit = true;
          form.addEventListener('submit', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var btn = form.querySelector('.mc-shoppable-card__atc');
            var orig = btn.textContent;
            btn.textContent = 'Adding...';
            btn.disabled = true;
            fetch('/cart/add.js', { method: 'POST', body: new FormData(form) })
              .then(function(r) { return r.json(); })
              .then(function() {
                btn.textContent = 'Added!';
                setTimeout(function() { btn.textContent = orig; btn.disabled = false; }, 1500);
                document.dispatchEvent(new CustomEvent('cart:update'));
              })
              .catch(function() {
                btn.textContent = 'Error';
                setTimeout(function() { btn.textContent = orig; btn.disabled = false; }, 1500);
              });
          });
        });
      })();
    </script>
  {%- endunless -%}
</div>
