{%- liquid
  comment
    Renders cart cross-sell products.

    Required parameters
    - cart: { Object } The current cart object
    - display: { String: 'grid' or 'slider' } Display of the cross sells snippet.

    Optional Parameters
    - position: { String: null or 'below-subtotal' } Position of the cross sells snippet on the cart page.
  endcomment

  assign product_limit = settings.cross_sells_max_products
  assign product_count = 0
  assign cart_item_ids = cart.items | map: 'product_id'
  assign use_metafield_source = false
  assign metafield_ids_blob = '|'

  if settings.cross_sells_recommendations_type == 'collection'
    assign product_pool = settings.collection.products
  elsif settings.cross_sells_recommendations_type == 'product-list'
    assign product_pool = settings.product_list
  elsif settings.cross_sells_recommendations_type == 'metafield'
    assign use_metafield_source = true
    assign product_limit = 3
  endif

  assign product_will_show = false

  if use_metafield_source
    for cart_item in cart.items
      assign source_product = cart_item.product
      assign parent_handle = cart_item.properties._bundle_parent_handle
      assign item_cross_sells = blank

      if source_product != blank
        if source_product.metafields.custom.cross_sell_product != blank
          assign item_cross_sells = source_product.metafields.custom.cross_sell_product.value
        elsif source_product.metafields.custom.cross_sell_products != blank
          assign item_cross_sells = source_product.metafields.custom.cross_sell_products.value
        endif
      endif

      if item_cross_sells == blank and parent_handle != blank and all_products[parent_handle] != blank
        assign parent_product = all_products[parent_handle]
        if parent_product.metafields.custom.cross_sell_product != blank
          assign item_cross_sells = parent_product.metafields.custom.cross_sell_product.value
        elsif parent_product.metafields.custom.cross_sell_products != blank
          assign item_cross_sells = parent_product.metafields.custom.cross_sell_products.value
        endif
      endif

      if item_cross_sells == blank
        continue
      endif

      for item in item_cross_sells
        if item == blank
          continue
        endif
        assign item_id_token = '|' | append: item.id | append: '|'
        if metafield_ids_blob contains item_id_token
          continue
        elsif cart_item_ids contains item.id
          continue
        elsif item.available == false
          continue
        else
          assign metafield_ids_blob = metafield_ids_blob | append: item.id | append: '|'
          assign product_will_show = true
          break
        endif
      endfor

      if product_will_show
        break
      endif
    endfor
  else
    for item in product_pool
      if cart_item_ids contains item.id
        continue
      elsif item.available == false
        continue
      else
        assign product_will_show = true
        break
      endif
    endfor
  endif

  assign is_slider = false

  if display == 'slider'
    assign is_slider = true
  endif
-%}

{%- if product_will_show -%}
  <div class="cross-sells" data-cross-sells data-position="{{ position }}">
    <div class="cross-sells__heading ff-heading fs-heading-6-base">{{ settings.cross_sells_heading }}</div>
    <div class="cross-sells__items {% if is_slider %}swiper{% endif %}" data-cross-sells-slider="{{ is_slider }}">
      {% if is_slider %}<div class="cross-sells__slider-inner swiper-wrapper">{% endif %}
      {%- if use_metafield_source -%}
        {%- assign rendered_metafield_ids = '|' -%}
        {%- for cart_item in cart.items -%}
          {%- assign source_product = cart_item.product -%}
          {%- assign parent_handle = cart_item.properties._bundle_parent_handle -%}
          {%- assign item_cross_sells = blank -%}

          {%- if source_product != blank -%}
            {%- if source_product.metafields.custom.cross_sell_product != blank -%}
              {%- assign item_cross_sells = source_product.metafields.custom.cross_sell_product.value -%}
            {%- elsif source_product.metafields.custom.cross_sell_products != blank -%}
              {%- assign item_cross_sells = source_product.metafields.custom.cross_sell_products.value -%}
            {%- endif -%}
          {%- endif -%}

          {%- if item_cross_sells == blank and parent_handle != blank and all_products[parent_handle] != blank -%}
            {%- assign parent_product = all_products[parent_handle] -%}
            {%- if parent_product.metafields.custom.cross_sell_product != blank -%}
              {%- assign item_cross_sells = parent_product.metafields.custom.cross_sell_product.value -%}
            {%- elsif parent_product.metafields.custom.cross_sell_products != blank -%}
              {%- assign item_cross_sells = parent_product.metafields.custom.cross_sell_products.value -%}
            {%- endif -%}
          {%- endif -%}

          {%- if item_cross_sells == blank -%}
            {%- continue -%}
          {%- endif -%}
          {%- for item in item_cross_sells -%}
            {%- if product_count >= product_limit -%}
              {%- break -%}
            {%- endif -%}
            {%- if item == blank -%}
              {%- continue -%}
            {%- endif -%}
            {%- assign item_id_token = '|' | append: item.id | append: '|' -%}
            {%- if rendered_metafield_ids contains item_id_token -%}
              {%- continue -%}
            {%- elsif cart_item_ids contains item.id -%}
              {%- continue -%}
            {%- elsif item.available == false -%}
              {%- continue -%}
            {%- endif -%}
            {%- assign rendered_metafield_ids = rendered_metafield_ids | append: item.id | append: '|' -%}
            {%- assign product_count = product_count | plus: 1 -%}
            {%- render 'cross-sells-item', item: item, is_slider: is_slider, cart: cart -%}
          {%- endfor -%}
          {%- if product_count >= product_limit -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for item in product_pool -%}
          {%- if product_count >= product_limit -%}
            {%- break -%}
          {%- elsif cart_item_ids contains item.id -%}
            {%- continue -%}
          {%- elsif item.available == false -%}
            {%- continue -%}
          {%- endif -%}
          {%- assign product_count = product_count | plus: 1 -%}
          {%- render 'cross-sells-item', item: item, is_slider: is_slider, cart: cart -%}
        {%- endfor -%}
      {%- endif -%}
      {% if is_slider %}
        </div>
        <button
          type="button"
          class="slider-nav-button slider-nav-button-prev"
          title="{{ 'general.accessibility.previous' | t }}"
          data-prev
        >
          {% render 'icon', icon: 'chevron' %}
        </button>
        <button
          type="button"
          class="slider-nav-button slider-nav-button-next"
          title="{{ 'general.accessibility.next' | t }}"
          data-next
        >
          {% render 'icon', icon: 'chevron' %}
        </button>
      {% endif %}
    </div>
  </div>
{%- endif -%}
