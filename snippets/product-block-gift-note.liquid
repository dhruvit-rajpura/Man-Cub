{%- liquid
  assign button_text = block.settings.button_text | default: '+ Add a Complementary Gift Note'
  assign placeholder = block.settings.placeholder | default: 'Your Message'
  assign max_chars = block.settings.max_characters | default: 250
  assign gift_label = block.settings.gift_label | default: 'Gift Message'
  assign top_spacing = block.settings.top_spacing | default: 0
  assign bottom_spacing = block.settings.bottom_spacing | default: 0
  assign button_style = block.settings.button_style | default: 'filled'
  assign button_bg = block.settings.button_color | default: '#000000'
  assign button_text_color = block.settings.button_text_color | default: '#ffffff'
-%}

<div class="product__block product-block-gift-note" {{ block.shopify_attributes }} style="padding-top: {{ top_spacing }}px; padding-bottom: {{ bottom_spacing }}px; --mc-gift-btn-bg: {{ button_bg }}; --mc-gift-btn-text: {{ button_text_color }};">
  <div class="mc-gift-note" data-mc-gift-note>
    <button
      type="button"
      class="mc-gift-note__toggle {% if button_style == 'filled' %}mc-gift-note__toggle--filled{% else %}mc-gift-note__toggle--outline{% endif %}"
      data-mc-gift-toggle
      aria-expanded="false"
    >
      <span class="mc-gift-note__toggle-icon" data-mc-gift-icon>+</span>
      <span>{{ button_text }}</span>
    </button>

    <div class="mc-gift-note__field" data-mc-gift-field style="display: none;">
      <textarea
        class="mc-gift-note__textarea"
        data-mc-gift-textarea
        name="properties[{{ gift_label }}]"
        placeholder="{{ placeholder }}"
        maxlength="{{ max_chars }}"
        rows="4"
        form="product-form-{{ section.id }}"
      ></textarea>
      <span class="mc-gift-note__counter" data-mc-gift-counter>0 / {{ max_chars }}</span>
    </div>
  </div>
</div>

<style>
  .mc-gift-note {
    width: 100%;
  }

  .mc-gift-note__toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-family: inherit;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 10px 20px;
    transition: all 0.2s ease;
    line-height: 1.3;
  }

  .mc-gift-note__toggle--filled {
    background: var(--mc-gift-btn-bg, #000);
    color: var(--mc-gift-btn-text, #fff);
    border: 1.5px solid var(--mc-gift-btn-bg, #000);
  }
  .mc-gift-note__toggle--filled:hover {
    opacity: 0.85;
  }

  .mc-gift-note__toggle--outline {
    background: transparent;
    color: var(--mc-gift-btn-bg, #000);
    border: 1.5px solid var(--mc-gift-btn-bg, #000);
  }
  .mc-gift-note__toggle--outline:hover {
    opacity: 0.7;
  }

  .mc-gift-note__toggle[aria-expanded="true"] .mc-gift-note__toggle-icon {
    transform: rotate(45deg);
  }

  .mc-gift-note__toggle-icon {
    font-size: 16px;
    font-weight: 400;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  .mc-gift-note__field {
    margin-top: 12px;
  }

  .mc-gift-note__textarea {
    width: 100%;
    border: 1px solid #ddd;
    padding: 12px 14px;
    font-family: inherit;
    font-size: 13px;
    line-height: 1.5;
    resize: vertical;
    min-height: 90px;
    color: inherit;
    background: transparent;
    transition: border-color 0.2s ease;
  }

  .mc-gift-note__textarea:focus {
    outline: none;
    border-color: #000;
  }

  .mc-gift-note__textarea::placeholder {
    color: #999;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 0.05em;
  }

  .mc-gift-note__counter {
    display: block;
    text-align: right;
    font-size: 11px;
    color: #999;
    margin-top: 4px;
  }
</style>

<script>
  (function() {
    var block = document.querySelector('[data-mc-gift-note]');
    if (!block) return;

    var toggle = block.querySelector('[data-mc-gift-toggle]');
    var field = block.querySelector('[data-mc-gift-field]');
    var textarea = block.querySelector('[data-mc-gift-textarea]');
    var counter = block.querySelector('[data-mc-gift-counter]');
    var maxChars = parseInt(textarea.getAttribute('maxlength')) || 250;
    var isOpen = false;

    toggle.addEventListener('click', function() {
      isOpen = !isOpen;
      toggle.setAttribute('aria-expanded', isOpen);
      if (isOpen) {
        field.style.display = 'block';
        textarea.focus();
      } else {
        field.style.display = 'none';
      }
    });

    function updateCounter() {
      counter.textContent = textarea.value.length + ' / ' + maxChars;
    }

    textarea.addEventListener('input', updateCounter);
  })();
</script>
